---
const links = [
  { href: '/materias', texto: 'Materias' },
  { href: '/como-trabajamos', texto: 'Cómo trabajamos' },
  { href: '/sobre-nosotros', texto: 'Sobre nosotros' },
  { href: '/info-estudiantes', texto: 'Info para estudiantes' },
  { href: '/blog', texto: 'Blog' },
];
---

<header class="site-header">
  <div class="contenedor header-inner">
    <a href="/" class="logo" aria-label="Delta Academia — inicio">
      <img src="/logo-wordmark.png" alt="Delta Academia" width="150" />
    </a>

    <nav class="nav-desktop" aria-label="Principal">
      {links.map((l) => <a href={l.href}>{l.texto}</a>)}
      <a href="/contacto" class="btn btn-primary btn-nav">Contacto</a>
    </nav>

    <button class="hamburguesa" aria-label="Abrir menú" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <nav class="nav-mobile" aria-label="Menú móvil">
    {links.map((l) => <a href={l.href}>{l.texto}</a>)}
    <a href="/contacto" class="btn btn-primary">Contacto</a>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(248, 249, 250, 0.9);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--borde);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }
  .logo img { height: 38px; width: auto; }
  .nav-desktop { display: flex; align-items: center; gap: var(--sp-3); }
  .nav-desktop a { font-weight: 500; font-size: 0.95rem; color: var(--texto); }
  .nav-desktop a:hover { color: var(--azul); }
  .btn-nav { color: #fff !important; }
  .hamburguesa {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }
  .hamburguesa span {
    width: 26px; height: 3px; border-radius: 2px;
    background: var(--azul); transition: all var(--trans);
  }
  .nav-mobile { display: none; flex-direction: column; padding: var(--sp-2) var(--sp-3) var(--sp-3); gap: var(--sp-2); }
  .nav-mobile a { font-weight: 500; padding: 6px 0; }

  @media (max-width: 860px) {
    .nav-desktop { display: none; }
    .hamburguesa { display: flex; }
    .nav-mobile.abierto { display: flex; border-top: 1px solid var(--borde); }
    .hamburguesa.activo span:nth-child(1) { transform: translateY(8px) rotate(45deg); }
    .hamburguesa.activo span:nth-child(2) { opacity: 0; }
    .hamburguesa.activo span:nth-child(3) { transform: translateY(-8px) rotate(-45deg); }
  }
</style>

<script>
  const btn = document.querySelector('.hamburguesa');
  const menu = document.querySelector('.nav-mobile');
  btn?.addEventListener('click', () => {
    const abierto = menu?.classList.toggle('abierto');
    btn.classList.toggle('activo');
    btn.setAttribute('aria-expanded', String(abierto));
  });
</script>
