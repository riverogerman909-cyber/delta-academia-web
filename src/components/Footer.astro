---
const anio = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="contenedor footer-grid">
    <div class="footer-marca">
      <img src="/logo-icon.png" alt="Delta Academia" width="52" height="52" />
      <p class="footer-lema">
        Acompañamiento paralelo a la facultad para estudiantes de
        <strong>FCEA — UdelaR</strong>. Clases por Zoom y material grabado.
      </p>
    </div>

    <div>
      <h4 class="footer-titulo">Materias</h4>
      <ul>
        <li><a href="/materias/conceptos-contables">Conceptos Contables</a></li>
        <li><a href="/materias/contabilidad-general-i">Contabilidad General I</a></li>
        <li><a href="/materias/derecho-actividad-empresarial-i">Derecho y Act. Empresarial I</a></li>
        <li><a href="/materias/contabilidad-general-iii">Contabilidad General III</a></li>
      </ul>
    </div>

    <div>
      <h4 class="footer-titulo">Navegación</h4>
      <ul>
        <li><a href="/como-trabajamos">Cómo trabajamos</a></li>
        <li><a href="/sobre-nosotros">Sobre nosotros</a></li>
        <li><a href="/info-estudiantes">Info para estudiantes</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/contacto">Contacto</a></li>
      </ul>
    </div>

    <div>
      <h4 class="footer-titulo">Contacto</h4>
      <ul>
        <li><a href="https://wa.me/59898521288" target="_blank" rel="noopener">WhatsApp +598 98 521 288</a></li>
        <li><a href="mailto:academiadelta5@gmail.com">academiadelta5@gmail.com</a></li>
        <li><a href="https://instagram.com/delta.academiagr" target="_blank" rel="noopener">@delta.academiagr</a></li>
      </ul>
      <a href="/contacto" class="btn btn-ambar" style="margin-top: 12px;">Escribinos</a>
    </div>
  </div>

  <div class="contenedor footer-base">
    <p>© {anio} Delta Academia. Todos los derechos reservados.</p>
    <p class="footer-nota">Contenido educativo independiente. No es un servicio oficial de la FCEA-UdelaR.</p>
  </div>
</footer>

<style>
  .site-footer { background: var(--azul); color: #cbd5e1; margin-top: var(--sp-12); }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: var(--sp-4);
    padding-top: var(--sp-8);
    padding-bottom: var(--sp-6);
  }
  .footer-marca img { border-radius: 12px; margin-bottom: var(--sp-2); }
  .footer-lema { font-size: 0.95rem; max-width: 30ch; }
  .footer-lema strong { color: #fff; }
  .footer-titulo { color: #fff; font-family: var(--fuente-texto); font-size: 0.85rem; letter-spacing: 1px; text-transform: uppercase; margin-bottom: var(--sp-2); }
  .site-footer ul { list-style: none; margin: 0; padding: 0; }
  .site-footer li { margin-bottom: 10px; }
  .site-footer a { color: #cbd5e1; font-size: 0.95rem; }
  .site-footer a:hover { color: var(--ambar); }
  .footer-base {
    display: flex; flex-wrap: wrap; justify-content: space-between; gap: var(--sp-1);
    border-top: 1px solid rgba(255,255,255,0.12);
    padding-top: var(--sp-3); padding-bottom: var(--sp-3);
    font-size: 0.85rem; color: #94a3b8;
  }
  .footer-base p { margin: 0; }
  @media (max-width: 820px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .footer-grid { grid-template-columns: 1fr; }
  }
</style>
